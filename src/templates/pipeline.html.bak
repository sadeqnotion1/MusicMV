<!DOCTYPE html>
<html class="dark" lang="en">
<head>
    <meta charset="utf-8"/>
    <meta content="width=device-width, initial-scale=1.0" name="viewport"/>
    <title>MusicMV - Control Panel</title>
    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com" rel="preconnect"/>
    <link crossorigin="" href="https://fonts.gstatic.com" rel="preconnect"/>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500&amp;family=Inter:wght@400;500;600&amp;family=Outfit:wght@500;600;700&amp;display=swap" rel="stylesheet"/>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
    <script id="tailwind-config">
        tailwind.config = {
            darkMode: "class",
            theme: {
                extend: {
                    "colors": {
                        "primary": "#8b5cf6",
                        "secondary": "#06b6d4",
                        "terminal-green": "#10b981",
                        "background": "#05060a",
                        "surface-glass": "rgba(20, 24, 38, 0.65)",
                        "border-glow": "rgba(139, 92, 246, 0.15)",
                        "text-primary": "#f8fafc",
                        "text-secondary": "#94a3b8",
                        "text-muted": "#475569"
                    }
                }
            }
        }
    </script>
    <style>
        ::-webkit-scrollbar {
            width: 6px;
            height: 6px;
        }
        ::-webkit-scrollbar-track {
            background: transparent;
        }
        ::-webkit-scrollbar-thumb {
            background: rgba(139, 92, 246, 0.2);
            border-radius: 4px;
        }
        ::-webkit-scrollbar-thumb:hover {
            background: rgba(139, 92, 246, 0.5);
        }
        .glass-panel {
            background-color: var(--bg-surface-glass);
            backdrop-filter: blur(20px);
            border: 1px solid var(--border-glow);
        }
        .btn-primary-glow {
            background: linear-gradient(135deg, #8b5cf6, #06b6d4);
            box-shadow: 0 0 15px rgba(139, 92, 246, 0.35);
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        .btn-primary-glow:hover {
            transform: translateY(-1px);
            box-shadow: 0 0 25px rgba(139, 92, 246, 0.55);
        }
        .btn-glass-cyan {
            background: rgba(255, 255, 255, 0.02);
            border: 1px solid rgba(6, 182, 212, 0.3);
            transition: all 0.3s ease;
        }
        .btn-glass-cyan:hover {
            border-color: #06b6d4;
            background: rgba(6, 182, 212, 0.08);
        }
    </style>
</head>
<body class="bg-[#05060a] text-[#f8fafc] min-h-screen overflow-hidden flex font-sans antialiased">

