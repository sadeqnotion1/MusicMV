                <span class="inline-flex items-center justify-center text-amber-400">
                    <!-- Billboard Logo SVG (local) -->
                    <svg viewBox="0 0 150 150" style="width:16px; height:16px; fill:currentColor !important;"><path d="M39.21,117.31v-5.25H23.04v5.25h16.17"/><path d="M39.2,110.21v-5.25H16.7v5.25h22.5"/><path d="M39.2,103.13v-5.25H16.7v5.25h22.5"/><path d="M22.88,41.98v-5.25h1.67c-1.26-.78-1.76-1.93-1.83-3.51h5.57v.62c0,1.86,1.07,2.89,3.05,2.89h7.71v5.25H22.88"/><path d="M19.01,117.73c-1.7,0-3.08-1.36-3.08-3.04s1.38-3.05,3.08-3.05,3.08,1.36,3.08,3.05-1.38,3.04-3.08,3.04"/><path d="M22.9,43.85v5.25h1.2c-.82,.74-1.49,2.45-1.49,3.76,0,4.58,3.53,7.67,8.5,7.67s8.18-3.48,8.18-7.73c0-1.31-.44-2.74-1.16-3.7h.91v-5.25h-7.08c-.29,0-.57,0-.85,0-.28,0-.56,0-.85,0h-7.37Zm11.07,8.71c0,1.68-1.38,3.04-3.08,3.04s-3.08-1.36-3.08-3.04,1.38-3.04,3.08-3.04,3.08,1.36,3.08,3.04"/><path d="M16.55,20.82h7.14c-.72,1.03-1.04,2.21-1.04,3.64,0,4.38,3.43,7.8,8.37,7.8,4.66,0,8.24-3.29,8.24-7.3,0-1.65-.53-2.98-1.7-4.23h1.48v-5.16H16.55v5.25Zm17.53,3.09c0,1.68-1.38,3.04-3.08,3.04s-3.08-1.36-3.08-3.04,1.38-3.05,3.08-3.05,3.08,1.36,3.08,3.05"/><path d="M22.81,87.11c0,1.43,.32,2.61,1.04,3.64h-7.14v5.25h22.5v-5.16h-1.48c1.16-1.24,1.7-2.58,1.7-4.23,0-4.01-3.59-7.3-8.24-7.3-4.94,0-8.37,3.42-8.37,7.8m11.46,.56c0,1.68-1.38,3.05-3.08,3.05s-3.08-1.36-3.08-3.05,1.38-3.04,3.08-3.04,3.08,1.36,3.08,3.04"/><path d="M22.81,126.45c0,1.43,.32,2.61,1.04,3.64h-7.14v5.25h22.5v-5.16h-1.48c1.16-1.24,1.7-2.58,1.7-4.23,0-4.01-3.59-7.3-8.24-7.3-4.94,0-8.37,3.42-8.37,7.8m11.46,.56c0,1.68-1.38,3.05-3.08,3.05s-3.08-1.36-3.08-3.05,1.38-3.04,3.08-3.04,3.08,1.36,3.08,3.04"/><path d="M95.29,48.09c-7.77,0-14.2,1.68-19.77,5.53V15.57h-28.55v119.86h28.05v-7.88c6.76,6.2,14.02,9.05,22.98,9.05,21.79,0,39.7-19.11,39.7-43.92,0-26.32-18.58-44.59-42.4-44.59m-3.04,61.08c-9.15,0-16.56-7.36-16.56-16.43s7.41-16.42,16.56-16.42,16.55,7.36,16.55,16.42-7.41,16.43-16.55,16.43"/><path d="M22.52,69.86c0,4.54,3.78,8.14,8.37,8.14s8.37-3.57,8.37-8.14-3.81-8.14-8.37-8.14-8.37,3.6-8.37,8.14m11.36,0c0,1.68-1.38,3.04-3.08,3.04s-3.08-1.36-3.08-3.04,1.38-3.04,3.08-3.04,3.08,1.36,3.08,3.04"/></svg>
                </span>
                Billboard Explorer
            </a>
            <!-- 3. YouTube Downloader -->
            <a class="flex items-center gap-4 px-6 py-3 text-[#94a3b8] font-medium hover:bg-white/3 hover:text-white transition-all duration-300 border-l-2 border-transparent" href="/?view=youtube">
                <span class="inline-flex items-center justify-center text-red-500">
                    <!-- YouTube Icon SVG (local) -->
                    <svg viewBox="0 0 28.57 20" style="width:16px; height:16px;"><g><path d="M27.9727 3.12324C27.6435 1.89323 26.6768 0.926623 25.4468 0.597366C23.2197 2.24288e-07 14.285 0 14.285 0C14.285 0 5.35042 2.24288e-07 3.12323 0.597366C1.89323 0.926623 0.926623 1.89323 0.597366 3.12324C2.24288e-07 5.35042 0 10 0 10C0 10 2.24288e-07 14.6496 0.597366 16.8768C0.926623 18.1068 1.89323 19.0734 3.12323 19.4026C5.35042 20 14.285 20 14.285 20C14.285 20 23.2197 20 25.4468 19.4026C26.6768 19.0734 27.6435 18.1068 27.9727 16.8768C28.5701 14.6496 28.5701 10 28.5701 10C28.5701 10 28.5677 5.35042 27.9727 3.12324Z" fill="#FF0000"></path><path d="M11.4253 14.2854L18.8477 10.0004L11.4253 5.71533V14.2854Z" fill="white"></path></g></svg>
                </span>
                YouTube Downloader
            </a>
            <!-- 4. Local Library -->
            <a class="flex items-center gap-4 px-6 py-3 text-[#94a3b8] font-medium hover:bg-white/3 hover:text-white transition-all duration-300 border-l-2 border-transparent" href="/library">
                <span class="inline-flex items-center justify-center text-text-secondary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M22 19a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h5l2 3h9a2 2 0 0 1 2 2z"></path>
                        <path d="M2 10h20"></path>
                    </svg>
                </span>
                Library Explorer
            </a>
            <!-- 5. Control Panel -->
            <a class="flex items-center gap-4 px-6 py-3 text-white font-bold border-l-2 border-primary bg-primary/10 transition-all duration-300" href="#">
                <span class="inline-flex items-center justify-center text-primary">
                    <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect>
                        <rect x="9" y="9" width="6" height="6"></rect>
                        <line x1="9" y1="1" x2="9" y2="4"></line>
                        <line x1="15" y1="1" x2="15" y2="4"></line>
                        <line x1="9" y1="20" x2="9" y2="23"></line>
                        <line x1="15" y1="20" x2="15" y2="23"></line>
                    </svg>
                </span>
                Control Panel
            </a>
        </div>
    </nav>

    <!-- Top Widescreen Header Bar -->
    <header class="fixed top-0 left-[260px] right-0 w-auto bg-transparent flex justify-between items-center h-16 px-8 z-40 pointer-events-none">
        <div class="flex items-center gap-4 pointer-events-auto">
            <h2 class="font-display-lg text-[20px] font-semibold text-white">Control Panel</h2>
        </div>
        <div class="flex items-center gap-4 pointer-events-auto">
            <button class="text-[#94a3b8] hover:text-secondary transition-colors opacity-80 p-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
            </button>
            <button class="text-[#94a3b8] hover:text-secondary transition-colors opacity-80 p-2">
                <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21.2 15a8.85 8.85 0 0 0-3.25-3.24 8.8 8.8 0 0 0-6.8 0A8.9 8.9 0 0 0 7.9 15"></path><circle cx="12" cy="12" r="10"></circle></svg>
            </button>
        </div>
    </header>

    <!-- Main Content Area -->
    <main class="ml-[260px] flex-1 mt-16 p-8 overflow-hidden flex flex-col relative">
        <!-- Ambient Background Glow -->
        <div class="absolute inset-0 pointer-events-none opacity-20">
            <div class="absolute top-[-10%] left-[-10%] w-[50%] h-[50%] rounded-full bg-primary blur-[120px]"></div>
            <div class="absolute bottom-[-10%] right-[-10%] w-[40%] h-[40%] rounded-full bg-secondary blur-[100px]"></div>
        </div>

        <div class="flex flex-row gap-6 h-full z-10 relative">
            <!-- Left Config Column (1/3 Width) -->
            <div class="w-1/3 h-full flex flex-col">
                <div class="bg-surface-glass border border-border-glow rounded-2xl p-6 h-full flex flex-col">
                    <h3 class="font-display-lg text-[18px] text-primary mb-6 flex items-center gap-2">
                        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="4" width="16" height="16" rx="2" ry="2"></rect><rect x="9" y="9" width="6" height="6"></rect><line x1="9" y1="1" x2="9" y2="4"></line><line x1="15" y1="1" x2="15" y2="4"></line></svg>
                        Pipeline Config
                    </h3>
                    <div class="flex flex-col gap-6 flex-1">
                        <div class="flex flex-col gap-2">
                            <label class="text-[10px] font-bold uppercase tracking-wider text-text-secondary">Root Video Directory</label>
                            <input id="root-directory" class="w-full h-[44px] bg-[#000000]/40 border border-border-glow rounded-lg px-4 font-mono text-sm text-[#f8fafc] focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none transition-all placeholder:text-text-muted" placeholder="/mnt/media/music_videos" type="text" value="G:\Music\Music Video"/>
                        </div>
                        <div class="flex flex-col gap-2">
                            <label class="text-[10px] font-bold uppercase tracking-wider text-text-secondary">Tidal API Token</label>
                            <input id="tidal-token" class="w-full h-[44px] bg-[#000000]/40 border border-border-glow rounded-lg px-4 font-mono text-sm text-[#f8fafc] focus:border-primary focus:ring-1 focus:ring-primary focus:outline-none transition-all placeholder:text-text-muted" placeholder="••••••••••••••••" type="password" value="CzET4vdadNUFQ5JU"/>
                        </div>
                        <hr class="border-border-glow/30 my-2"/>
                        <div class="flex flex-col gap-4">
                            <label class="flex items-center gap-3 cursor-pointer group">
                                <input id="sync-avatars" checked class="accent-primary w-4 h-4 rounded border-border-glow bg-black/40" type="checkbox"/>
                                <span class="text-sm text-text-secondary group-hover:text-white transition-colors">Sync Deezer Avatars</span>
                            </label>
                            <label class="flex items-center gap-3 cursor-pointer group">
                                <input id="generate-catalogs" checked class="accent-primary w-4 h-4 rounded border-border-glow bg-black/40" type="checkbox"/>
                                <span class="text-sm text-text-secondary group-hover:text-white transition-colors">Generate Catalogs</span>
                            </label>
                            <label class="flex items-center gap-3 cursor-pointer group">
                                <input id="reconcile-shortcuts" class="accent-primary w-4 h-4 rounded border-border-glow bg-black/40" type="checkbox"/>
                                <span class="text-sm text-text-secondary group-hover:text-white transition-colors">Reconcile Guest Shortcuts</span>
                            </label>
                        </div>
                        <hr class="border-border-glow/30 my-2"/>
                        <div class="flex flex-col gap-3">
                            <label class="text-[10px] font-bold uppercase tracking-wider text-text-secondary">Library Scan Stats</label>
                            <div class="grid grid-cols-2 gap-2 text-xs">
                                <div class="bg-black/35 border border-border-glow/25 p-2 rounded-lg flex flex-col">
                                    <span class="text-text-muted text-[10px] uppercase font-semibold">Artists</span>
                                    <span id="stat-artists" class="text-white font-bold text-sm mt-0.5">-</span>
                                </div>
                                <div class="bg-black/35 border border-border-glow/25 p-2 rounded-lg flex flex-col">
                                    <span class="text-text-muted text-[10px] uppercase font-semibold">Videos</span>
                                    <span id="stat-videos" class="text-white font-bold text-sm mt-0.5">-</span>
                                </div>
                                <div class="bg-black/35 border border-border-glow/25 p-2 rounded-lg flex flex-col">
                                    <span class="text-text-muted text-[10px] uppercase font-semibold">Shortcuts</span>
                                    <span id="stat-shortcuts" class="text-white font-bold text-sm mt-0.5">-</span>
                                </div>
                                <div class="bg-black/35 border border-border-glow/25 p-2 rounded-lg flex flex-col">
                                    <span class="text-text-muted text-[10px] uppercase font-semibold">History Cache</span>
                                    <span id="stat-cached" class="text-white font-bold text-sm mt-0.5">-</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column (2/3 Width) -->
            <div class="w-2/3 h-full flex flex-col gap-6">
                <!-- Action Row -->
                <div class="bg-surface-glass border border-border-glow rounded-2xl p-6 flex items-center justify-between">
                    <div class="flex items-center gap-4">
                        <button id="btn-run-master" class="btn-primary-glow px-6 py-3 rounded-lg flex items-center gap-2 font-bold text-sm text-white transition-all disabled:opacity-50 disabled:pointer-events-none">
                            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polygon points="5 3 19 12 5 21 5 3"></polygon></svg>
                            Run Master Pipeline
                        </button>
                        <!-- Pipeline Status Badge -->
                        <div id="pipeline-status-badge" class="hidden flex items-center gap-2 px-3 py-1.5 rounded-full bg-primary/10 border border-primary/30 text-xs font-semibold text-primary">
                            <span class="w-1.5 h-1.5 rounded-full bg-primary animate-ping"></span>
                            <span id="pipeline-status-text">Idle</span>
                        </div>
                    </div>
                    <div class="flex gap-4">
                        <button id="btn-process-guests" class="btn-glass-cyan px-4 py-2 rounded-lg font-bold text-xs text-secondary hover:text-white disabled:opacity-50 disabled:pointer-events-none">
                            Process Guests Only
                        </button>
                        <button id="btn-fetch-avatars" class="btn-glass-cyan px-4 py-2 rounded-lg font-bold text-xs text-secondary hover:text-white disabled:opacity-50 disabled:pointer-events-none">
                            Fetch Avatars Only
                        </button>
                    </div>
                </div>
                <!-- Console Terminal -->
                <div class="flex-1 rounded-2xl overflow-hidden border border-border-glow flex flex-col shadow-[inset_0_0_20px_rgba(0,0,0,0.8)] bg-black relative">
                    <!-- Title Bar -->
                    <div class="h-8 bg-[#15171d] border-b border-border-glow flex items-center px-4 relative z-10">
                        <div class="flex gap-2">
                            <div class="w-3 h-3 rounded-full bg-[#FF5F56] border border-[#E0443E]"></div>
                            <div class="w-3 h-3 rounded-full bg-[#FFBD2E] border border-[#DEA123]"></div>
                            <div class="w-3 h-3 rounded-full bg-[#27C93F] border border-[#1AAB29]"></div>
                        </div>
                        <div class="absolute inset-0 flex items-center justify-center pointer-events-none">
                            <span class="font-mono text-[11px] text-text-secondary">system_orchestrator.log</span>
                        </div>
                    </div>
                    <!-- Body -->
                    <div id="console-body" class="flex-1 p-6 overflow-y-auto font-mono text-[13px] leading-relaxed text-[#f8fafc] flex flex-col gap-1.5">
                        <div class="text-text-muted">Loading logs...</div>
                        <div class="animate-pulse flex items-center gap-1"><span class="text-terminal-green">_</span></div>
                    </div>
                </div>
            </div>
        </div>
    </main>

    <script>
        let activeTimer = null;
        let isPipelineRunning = false;

        // Helper: Escape HTML string
        function escapeHTML(str) {
            if (!str) return '';
            return str.replace(/[&<>'"]/g, 
                tag => ({
                    '&': '&amp;',
                    '<': '&lt;',
                    '>': '&gt;',
                    "'": '&#39;',
                    '"': '&quot;'
                }[tag] || tag)
            );
        }

        // Load status and populate UI
        async function loadStatus() {
            const rootDirInput = document.getElementById('root-directory');
            const path = rootDirInput ? rootDirInput.value.trim() : '';
            
            try {
                // Append path in GET query if provided, so we get stats for that specific folder
                const url = path ? `/api/archive/status?path=${encodeURIComponent(path)}` : '/api/archive/status';
                const response = await fetch(url);
                const data = await response.json();
                
                if (data.status === 'success') {
                    // Update stats
                    document.getElementById('stat-artists').textContent = data.stats.artists.toLocaleString();
                    document.getElementById('stat-videos').textContent = data.stats.videos.toLocaleString();
                    document.getElementById('stat-shortcuts').textContent = data.stats.shortcuts.toLocaleString();
                    document.getElementById('stat-cached').textContent = data.stats.cached.toLocaleString();
                    
                    // Populate initial configuration settings
                    if (!window.configLoaded && data.config) {
                        if (rootDirInput) rootDirInput.value = data.config.path;
                        document.getElementById('tidal-token').value = data.config.tidalToken || '';
                        document.getElementById('sync-avatars').checked = data.config.syncDeezerAvatars;
                        document.getElementById('generate-catalogs').checked = data.config.generateCatalogs;
                        document.getElementById('reconcile-shortcuts').checked = data.config.reconcileShortcuts;
                        window.configLoaded = true;
                    }
                    
                    // Update Pipeline run status
                    updatePipelineStatus(data.pipelineRunning, data.pipelineStatusText);
                }
            } catch (err) {
                console.error("Error fetching status:", err);
            }
        }

        // Poll logs
        async function pollLogs() {
            try {
                const response = await fetch('/api/archive/logs');
                const logs = await response.json();
                renderLogs(logs);
            } catch (err) {
                console.error("Error fetching logs:", err);
            }
        }

        // Render logs to terminal
        function renderLogs(logs) {
            const consoleBody = document.getElementById('console-body');
            if (!consoleBody) return;
            
            if (!logs || logs.length === 0) {
                consoleBody.innerHTML = `
                    <div class="text-text-muted">[System IDLE] No active operations run. Waiting for trigger...</div>
                    <div class="animate-pulse flex items-center gap-1"><span class="text-terminal-green">_</span></div>
                `;
                return;
            }
            
            let html = '';
            logs.forEach(log => {
                let levelClass = 'text-text-secondary';
                if (log.level === 'SUCCESS' || log.level === 'OK') {
                    levelClass = 'text-terminal-green font-semibold';
                } else if (log.level === 'WARNING') {
                    levelClass = 'text-[#f59e0b] font-semibold';
                } else if (log.level === 'ERROR') {
                    levelClass = 'text-[#ef4444] font-bold';
                } else if (log.level === 'INFO') {
                    levelClass = 'text-secondary';
                } else if (log.level === 'DEBUG') {
                    levelClass = 'text-text-muted';
                }
                
                html += `<div><span class="text-text-muted">[${log.time}]</span> <span class="${levelClass}">${log.level}:</span> ${escapeHTML(log.message)}</div>`;
            });
            
            // Blink indicator at bottom
            html += `<div class="animate-pulse flex items-center gap-1"><span class="text-text-muted">[${new Date().toLocaleTimeString([], {hour: '2-digit', minute:'2-digit', second:'2-digit', hour12:false})}]</span> <span class="text-terminal-green">_</span></div>`;
            
            const isScrolledToBottom = consoleBody.scrollHeight - consoleBody.clientHeight <= consoleBody.scrollTop + 60;
            consoleBody.innerHTML = html;
            
            if (isScrolledToBottom || !window.hasUserScrolledConsole) {
                consoleBody.scrollTop = consoleBody.scrollHeight;
            }
        }

        // Track if user scrolled the console manually
        document.getElementById('console-body').addEventListener('scroll', function(e) {
            const el = e.target;
            // User is near the bottom
            if (el.scrollHeight - el.clientHeight <= el.scrollTop + 30) {
                window.hasUserScrolledConsole = false;
            } else {
                window.hasUserScrolledConsole = true;
            }
        });

        // Update buttons/status display based on pipeline state
        function updatePipelineStatus(running, statusText) {
            isPipelineRunning = running;
            
            const badge = document.getElementById('pipeline-status-badge');
            const badgeText = document.getElementById('pipeline-status-text');
            const btnMaster = document.getElementById('btn-run-master');
            const btnGuests = document.getElementById('btn-process-guests');
            const btnAvatars = document.getElementById('btn-fetch-avatars');
            
            const inputs = [
                document.getElementById('root-directory'),
                document.getElementById('tidal-token'),
                document.getElementById('sync-avatars'),
                document.getElementById('generate-catalogs'),
                document.getElementById('reconcile-shortcuts')
            ];
            
            if (running) {
                badge.classList.remove('hidden');
                badgeText.textContent = statusText || 'Running...';
                
                // Disable actions
                btnMaster.disabled = true;
                btnMaster.classList.add('opacity-50');
                if (btnGuests) { btnGuests.disabled = true; btnGuests.classList.add('opacity-50'); }
                if (btnAvatars) { btnAvatars.disabled = true; btnAvatars.classList.add('opacity-50'); }
                
                inputs.forEach(i => { if (i) i.disabled = true; });
                
                // Speed up polling
                startPolling(1000);
            } else {
                badge.classList.add('hidden');
                badgeText.textContent = 'Idle';
                
                // Enable actions
                btnMaster.disabled = false;
                btnMaster.classList.remove('opacity-50');
                if (btnGuests) { btnGuests.disabled = false; btnGuests.classList.remove('opacity-50'); }
                if (btnAvatars) { btnAvatars.disabled = false; btnAvatars.classList.remove('opacity-50'); }
                
                inputs.forEach(i => { if (i) i.disabled = false; });
                
                // Slow down polling when idle
                startPolling(4000);
            }
        }

        // Save UI config state to backend
        async function saveConfig() {
            const path = document.getElementById('root-directory').value.trim();
            const tidalToken = document.getElementById('tidal-token').value.trim();
            const syncDeezerAvatars = document.getElementById('sync-avatars').checked;
            const generateCatalogs = document.getElementById('generate-catalogs').checked;
            const reconcileShortcuts = document.getElementById('reconcile-shortcuts').checked;

            try {
                await fetch('/api/archive/status', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        path,
                        tidalToken,
                        syncDeezerAvatars,
                        generateCatalogs,
                        reconcileShortcuts
                    })
                });
            } catch (err) {
                console.error("Error saving configuration:", err);
            }
        }

        // Trigger standard run pipeline
        async function runMasterPipeline() {
            if (isPipelineRunning) return;
            
            // Save first
            await saveConfig();
            
            const path = document.getElementById('root-directory').value.trim();
            const syncDeezerAvatars = document.getElementById('sync-avatars').checked;
            const generateCatalogs = document.getElementById('generate-catalogs').checked;
            const reconcileShortcuts = document.getElementById('reconcile-shortcuts').checked;
            
            try {
                const response = await fetch('/api/archive/run', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        path: path,
                        commit: reconcileShortcuts, // Reconciler and Organizer commit flag
                        skipIcons: !syncDeezerAvatars,
                        skipDeezer: !generateCatalogs,
                        force: false,
                        historyDays: 7
                    })
                });
                const data = await response.json();
                if (data.status === 'success') {
                    updatePipelineStatus(true, "Starting master pipeline...");
                    pollLogs();
                } else {
                    alert("Error starting pipeline: " + data.message);
                }
            } catch (err) {
                console.error("Error executing master pipeline:", err);
                alert("Connection error starting pipeline.");
            }
        }

        // Trigger Process Guests Only (Quick shortcuts compile, skip avatars and Deezer search)
        async function runProcessGuests() {
            if (isPipelineRunning) return;
            
            await saveConfig();
            const path = document.getElementById('root-directory').value.trim();
            
            try {
                const response = await fetch('/api/archive/run', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        path: path,
                        commit: true,
                        skipIcons: true,
                        skipDeezer: true,
                        force: false
                    })
                });
                const data = await response.json();
                if (data.status === 'success') {
                    updatePipelineStatus(true, "Processing guest collaborator shortcuts...");
                    pollLogs();
                } else {
                    alert("Error starting pipeline: " + data.message);
                }
            } catch (err) {
                console.error(err);
                alert("Connection error.");
            }
        }

        // Trigger Fetch Avatars Only (Dry run sorting, sync profiles)
        async function runFetchAvatars() {
            if (isPipelineRunning) return;
            
            await saveConfig();
            const path = document.getElementById('root-directory').value.trim();
            
            try {
                const response = await fetch('/api/archive/run', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({
                        path: path,
                        commit: false,
                        skipIcons: false,
                        skipDeezer: true,
                        force: false
                    })
                });
                const data = await response.json();
                if (data.status === 'success') {
                    updatePipelineStatus(true, "Downloading artist avatars...");
                    pollLogs();
                } else {
                    alert("Error starting pipeline: " + data.message);
                }
            } catch (err) {
                console.error(err);
                alert("Connection error.");
            }
        }

        // Start polling helper to manage timer interval
        function startPolling(ms) {
            if (activeTimer) {
                clearInterval(activeTimer);
            }
            
            activeTimer = setInterval(() => {
                loadStatus();
                pollLogs();
            }, ms);
        }

        // Event listeners
        document.addEventListener('DOMContentLoaded', () => {
            window.configLoaded = false;
            window.hasUserScrolledConsole = false;
            
            // Initial status load
            loadStatus().then(() => {
                pollLogs();
            });
            
            // Bind primary buttons
            document.getElementById('btn-run-master').addEventListener('click', runMasterPipeline);
            
            const btnGuests = document.getElementById('btn-process-guests');
            if (btnGuests) btnGuests.addEventListener('click', runProcessGuests);
            
            const btnAvatars = document.getElementById('btn-fetch-avatars');
            if (btnAvatars) btnAvatars.addEventListener('click', runFetchAvatars);
            
            // Bind inputs to save configuration on change/blur
            const configInputs = [
                document.getElementById('root-directory'),
                document.getElementById('tidal-token'),
                document.getElementById('sync-avatars'),
                document.getElementById('generate-catalogs'),
                document.getElementById('reconcile-shortcuts')
            ];
            
            configInputs.forEach(input => {
                if (!input) return;
                const eventType = input.type === 'checkbox' ? 'change' : 'blur';
                input.addEventListener(eventType, async () => {
                    if (!isPipelineRunning) {
                        await saveConfig();
                        // If directory changed, reload stats immediately
                        if (input.id === 'root-directory') {
                            loadStatus();
                        }
                    }
                });
            });
        });
    </script>
</body>
</html>